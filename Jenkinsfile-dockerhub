pipeline {
    agent any

    options {
        timeout(time: 10, unit: 'MINUTES')
    }

    environment {
        DOCKERHUB_CREDENTIALS = credentials('linsmedtech-dockerhub')
        APP_NAME = "linsmedtech/amazon2"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Linsmed/Amazon-clone-Dockerized.git'
            }
        }

        stage('Docker Login') {
            steps {
                sh '''
                echo $DOCKERHUB_CREDENTIALS_PSW | docker login \
                -u $DOCKERHUB_CREDENTIALS_USR \
                --password-stdin
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                docker build -t $APP_NAME:$BUILD_NUMBER .
                '''
            }
        }

        stage('Trivy Security Scan') {
            steps {
                sh '''
                trivy image --exit-code 1 --severity HIGH,CRITICAL $APP_NAME:$BUILD_NUMBER
                '''
            }
        }

        stage('Push Image to DockerHub') {
            steps {
                sh '''
                docker push $APP_NAME:$BUILD_NUMBER
                '''
            }
        }

        stage('Trigger ArgoCD Manifest Update') {
            steps {
                build job: 'argocd-manifest-amazon',
                parameters: [
                    string(name: 'DOCKERTAG', value: env.BUILD_NUMBER)
                ]
            }
        }

    }
}
